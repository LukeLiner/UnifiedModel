        '''
        
        for field_name, field_info in expanded_fields.items():
            desc = ''
            if 'description' in field_info:
                desc_info = field_info['description']
                if isinstance(desc_info, dict):
                    desc = desc_info.get('zh_cn', desc_info.get('en_us', ''))
                else:
                    desc = str(desc_info)
            
            required = '否'
            constraint = field_info.get('constraint', {})
            if isinstance(constraint, dict) and constraint.get('required', False):
                required = '是'
            
            default_value = self._get_default_value(field_info)
            default_display = self._format_value(default_value) if default_value is not None else '-'
            
            html += f'''
            <tr class="unconfigured-field">
                <td><strong>{field_name}</strong></td>
                <td><span class="tag tag-type">{field_info.get('type', 'unknown')}</span></td>
                <td>{desc}</td>
                <td>{required}</td>
                <td>{default_display}</td>
            </tr>
            '''
        
        html += '''
            </tbody>
        </table>
        <p class="unconfigured-value" style="margin-top: 10px;">⚠️ 字段未配置，以上为expanded schema中定义的字段结构</p>
        '''
        
        return html
    
    def _generate_filters_table(self, data: List[Dict]) -> str:
        """生成过滤器表格"""
        if not data:
            return '<p class="unconfigured-value">未配置过滤器</p>'
            
        html = '''
        <table class="data-table">
            <thead>
                <tr>
                    <th>名称</th>
                    <th>显示名称（中文）</th>
                    <th>显示名称（English）</th>
                    <th>描述（中文）</th>
                    <th>描述（English）</th>
                    <th>类型</th>
                    <th>操作符</th>
                    <th>示例</th>
                </tr>
            </thead>
            <tbody>
        '''
        
        for filter_item in data:
            # 提取多语言内容
            display_name_zh = ''
            display_name_en = ''
            if 'display_name' in filter_item:
                if isinstance(filter_item['display_name'], dict):
                    display_name_zh = filter_item['display_name'].get('zh_cn', '')
                    display_name_en = filter_item['display_name'].get('en_us', '')
                else:
                    display_name_zh = str(filter_item['display_name'])
            
            desc_zh = ''
            desc_en = ''
            if 'description' in filter_item:
                if isinstance(filter_item['description'], dict):
                    desc_zh = filter_item['description'].get('zh_cn', '')
                    desc_en = filter_item['description'].get('en_us', '')
                else:
                    desc_zh = str(filter_item['description'])
            
            operators = ', '.join(filter_item.get('operators', []))
            
            html += f'''
            <tr>
                <td><strong>{filter_item.get('name', '')}</strong></td>
                <td>{display_name_zh}</td>
                <td>{display_name_en}</td>
                <td>{desc_zh}</td>
                <td>{desc_en}</td>
                <td><span class="tag tag-type">{filter_item.get('type', 'string')}</span></td>
                <td><code class="code">{operators}</code></td>
                <td><code class="code">{filter_item.get('example', '')}</code></td>
            </tr>
            '''
        
        html += '''
            </tbody>
        </table>
        '''
        
        return html
    
    def _generate_properties_table(self, data: List[Dict]) -> str:
        """生成属性表格"""
        html = '''
        <table class="data-table">
            <thead>
                <tr>
                    <th>属性名</th>
                    <th>类型</th>
                    <th>描述（中文）</th>
                    <th>描述（English）</th>
                    <th>必填</th>
                    <th>默认值</th>
                    <th>约束条件</th>
                </tr>
            </thead>
            <tbody>
        '''
        
        for prop in data:
            configured = prop.get('configured', True)
            row_class = '' if configured else ' class="unconfigured-row"'
            
            required = '✅' if prop['required'] else '❌'
            
            # 处理描述
            desc_zh = prop['description_zh'] if configured else f'<span class="unconfigured">{prop["description_zh"]}</span>'
            desc_en = prop['description_en'] if configured else f'<span class="unconfigured">{prop["description_en"]}</span>'
            
            # 处理约束条件
            constraints_html = ''
            if prop['constraints']:
                constraints_html = '<ul class="constraints-list">'
                for constraint in prop['constraints']:
                    constraints_html += f'<li>{constraint}</li>'
                constraints_html += '</ul>'
            
            html += f'''
            <tr{row_class}>
                <td><strong>{prop['name']}</strong></td>
                <td><span class="tag tag-type">{prop['type']}</span></td>
                <td>{desc_zh}</td>
                <td>{desc_en}</td>
                <td style="text-align: center;">{required}</td>
                <td><code class="code">{prop['default']}</code></td>
                <td>{constraints_html}</td>
            </tr>
            '''
        
        html += '''
            </tbody>
        </table>
        '''
        
        return html


def main():
    parser = argparse.ArgumentParser(description='将 umodel schema 转换为表格形式的 HTML 文档')
    parser.add_argument('input', help='输入的 YAML 文件路径')
    parser.add_argument('-o', '--output', help='输出的 HTML 文件路径')
    
    args = parser.parse_args()
    
    # 检查输入文件
    if not os.path.exists(args.input):
        print(f"❌ 错误: 文件 {args.input} 不存在")
        return
    
    if not args.input.endswith(('.yaml', '.yml')):
        print(f"❌ 错误: 输入文件必须是 YAML 文件")
        return
    
    # 如果没有指定输出文件，自动生成
    if not args.output:
        base_name = os.path.splitext(os.path.basename(args.input))[0]
        args.output = f"{base_name}_table.html"
    
    converter = SchemaToTableHtmlConverter()
    
    try:
        converter.convert_file(args.input, args.output)
        print(f"🎉 转换完成！")
        print(f"📄 输出文件: {args.output}")
        print(f"💡 提示: 可以在浏览器中打开查看")
        
    except Exception as e:
        print(f"❌ 转换失败: {str(e)}")
        import traceback
        traceback.print_exc()


if __name__ == "__main__":
    main() 